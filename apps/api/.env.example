# --- Server ---
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
# Comma-separated allowlist of frontend origins (CORS). Behind Cloudflare Tunnel use the public origin.
CORS_ORIGINS=http://localhost:5173

# --- Auth ---
# 32+ char random secret for signing JWTs. CHANGE IN PRODUCTION.
JWT_SECRET=change_me_dev_only_minimum_32_characters_long
# Token lifetime (e.g. 12h, 24h)
TOKEN_TTL=12h

# --- Sessions ---
SESSION_TTL_HOURS=12
# Wrong-secret attempts before ousado activation locks
OUSADO_MAX_TRIES=5
OUSADO_LOCK_MINUTES=15
# Public base used to build the join URL embedded in the QR code
PUBLIC_APP_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=file:./data/deckofus.db

# --- Storage ---
# local = save to disk (dev/CI), cloudreve = forward to Cloudreve
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./data/uploads
# Served publicly for local driver (behind tunnel: the public origin + /uploads)
LOCAL_PUBLIC_BASE=http://localhost:8080/uploads

# --- Cloudreve v4 OAuth (when STORAGE_DRIVER=cloudreve) ---
# Create an OAuth app (Dashboard -> OAuth Apps) with scopes
# `openid Files.Write offline_access`, then do a one-time authorize to obtain a
# refresh_token. The backend exchanges it for short-lived access tokens.
CLOUDREVE_BASE_URL=https://cloudreve.example.com
CLOUDREVE_CLIENT_ID=
CLOUDREVE_CLIENT_SECRET=
CLOUDREVE_REFRESH_TOKEN=
# Destination folder as a v4 file URI (filename is appended automatically).
CLOUDREVE_FOLDER=cloudreve://my/deckofus

# --- Trust proxy (Cloudflare Tunnel / Traefik) ---
# true to trust X-Forwarded-* / CF-Connecting-IP for real client IP
TRUST_PROXY=false